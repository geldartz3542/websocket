# ─── Digisaka WebSocket Server (Local Dev) ──────────
PORT=6001
HOST=0.0.0.0

APP_ID=digisaka
APP_KEY=digisaka-ws-key-2026
APP_SECRET=digiSaka2026

ALLOWED_ORIGINS=*

AUTH_ENDPOINT=https://digisaka.online/api/broadcasting/auth

RATE_LIMIT_POINTS=120
RATE_LIMIT_DURATION=60

HEARTBEAT_INTERVAL=25000
MAX_CONNECTIONS_PER_IP=0
MAX_PAYLOAD_SIZE=65536

LOG_LEVEL=debug

# Dashboard & documentation password (leave empty to disable)
DASHBOARD_PASSWORD=!Asdasd123

# Webhook — Laravel endpoint called when an identified user disconnects (all connections closed)
DISCONNECT_WEBHOOK_URL=https://digisaka.online/api/webhooks/user-offline
