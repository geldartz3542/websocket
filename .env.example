# ─── Digisaka WebSocket Server ───────────────────────
# Copy this to .env and fill in your values

# Server
PORT=6001
HOST=0.0.0.0

# App credentials (generate random strings for production)
APP_ID=digisaka
APP_KEY=digisaka-ws-key-2026
APP_SECRET=digisaka-ws-secret-change-me-in-production

# CORS — comma-separated origins allowed to connect
ALLOWED_ORIGINS=https://digisaka.online,https://digisaka.app,http://localhost:5173,http://localhost:8000

# Auth callback — Laravel endpoint to validate private/presence channel subscriptions
AUTH_ENDPOINT=https://digisaka.online/api/broadcasting/auth

# Rate limiting
RATE_LIMIT_POINTS=60
RATE_LIMIT_DURATION=60

# Heartbeat interval (ms)
HEARTBEAT_INTERVAL=25000

# Max connections per IP (0 = unlimited)
MAX_CONNECTIONS_PER_IP=50

# Max payload size in bytes (64KB)
MAX_PAYLOAD_SIZE=65536

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# Dashboard & documentation password (leave empty to disable)
DASHBOARD_PASSWORD=

# SSL (optional — set if terminating SSL here instead of reverse proxy)
# SSL_CERT_PATH=
# SSL_KEY_PATH=
